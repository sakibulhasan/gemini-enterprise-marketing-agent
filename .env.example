# =============================================================================
# Cadence - Gemini Enterprise Marketing Agent : environment configuration
# Copy this file to ".env" and fill in your own values.
# =============================================================================

# ---- Google Cloud project ----
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Tell the ADK / Vertex AI SDK to use Vertex AI (not the public Gemini API).
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# ---- Cloud Storage connector (Source 1: Google Ads + Recommendations export) ----
# Bucket where the synthetic Google Ads recommendation export lands. The agent
# reads the JSONL objects here DIRECTLY (no BigQuery external table).
GCS_BUCKET=your-gcp-project-id-ads-export
GCS_ADS_PREFIX=google_ads_export

# ---- BigQuery connector (Source 2: FleetSync capacity / dispatch) ----
BQ_DATASET=fleetsync
# Location for the BigQuery dataset.
BQ_LOCATION=US

# ---- REST connector (Source 3: live, free Open-Meteo API - no key required) ----
# Open-Meteo is free for non-commercial use and needs no API key.
WEATHER_API_BASE=https://api.open-meteo.com/v1/forecast

# ---- Agent Engine deployment ----
AGENT_ENGINE_STAGING_BUCKET=gs://your-gcp-project-id-cadence-staging
AGENT_DISPLAY_NAME="Cadence Budget Capacity Agent"

# ---- Agent model (optional — defaults to gemini-2.5-flash) ----
# Override to switch model without changing code.
# CADENCE_MODEL=gemini-2.5-flash
